# withyou+ 메일 발송(SMTP) 설정 예시 — 복사해서 .env 로 만들고 값 채우기
# MAIL_USERNAME / MAIL_PASSWORD 를 채우면 실제 인증 메일 발송, 비우면 데모 모드.

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM_NAME=withyou+

# AI 대화/선물 추천
# AI_PROVIDER: gemini | claude | demo (키를 비우면 자동으로 demo 응답)
# 현재는 Gemini, 추후 ANTHROPIC_API_KEY 채우고 AI_PROVIDER=claude 로 전환.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
